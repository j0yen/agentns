From: j0yen <jyen.tech@gmail.com>
Date: 2026-05-24
Subject: [PATCH 08/10] syscalls: count openat/write/connect/unlink per agent NS

Wire the fast-path inline counters into the high-traffic syscall paths.
These compile to a single NULL check + per-cpu add when AGENT_NS=n and
to a few extra cycles when the calling task is in an agent NS.

Signed-off-by: j0yen <jyen.tech@gmail.com>
---
 fs/namei.c   | 4 ++++
 fs/open.c    | 4 ++++
 fs/read_write.c | 6 ++++++
 net/socket.c | 2 ++
 4 files changed, 16 insertions(+)

--- a/fs/open.c
+++ b/fs/open.c
@@ -39,6 +39,7 @@
 #include <linux/dnotify.h>
 #include <linux/compat.h>
 #include <linux/mnt_idmapping.h>
+#include <linux/agent_namespaces.h>

 #include "internal.h"

@@ -1339,6 +1340,9 @@ static long do_sys_openat2(int dfd, const char __user *filename,
 		}
 	}
 	putname(tmp);
+	if (fd >= 0)
+		agent_ns_count_openat();
+
 	return fd;
 }

--- a/fs/read_write.c
+++ b/fs/read_write.c
@@ -22,6 +22,7 @@
 #include <linux/uio.h>
 #include <linux/compat.h>
 #include <linux/mount.h>
+#include <linux/agent_namespaces.h>

 #include <linux/uaccess.h>
 #include <asm/unistd.h>
@@ -609,6 +610,8 @@ ssize_t ksys_write(unsigned int fd, const char __user *buf, size_t count)
 			file_pos_write(f.file, pos);
 		fdput_pos(f);
 	}
+	if (ret > 0)
+		agent_ns_count_write(ret);

 	return ret;
 }
@@ -670,6 +673,9 @@ ssize_t ksys_pwrite64(unsigned int fd, const char __user *buf,
 			ret = vfs_write(f.file, buf, count, &pos);
 		fdput(f);
 	}
+	if (ret > 0)
+		agent_ns_count_write(ret);
+
 	return ret;
 }

--- a/fs/namei.c
+++ b/fs/namei.c
@@ -41,6 +41,7 @@
 #include <linux/init_task.h>
 #include <linux/uaccess.h>
 #include <linux/build_bug.h>
+#include <linux/agent_namespaces.h>

 #include "internal.h"
 #include "mount.h"
@@ -4326,6 +4327,9 @@ int do_unlinkat(int dfd, struct filename *name)

 	dput(dentry);
 	mnt_drop_write(path.mnt);
+	if (!error)
+		agent_ns_count_unlink();
+
 exit2:
 	inode_unlock(path.dentry->d_inode);
 	if (inode)

--- a/net/socket.c
+++ b/net/socket.c
@@ -94,6 +94,7 @@
 #include <linux/xattr.h>
 #include <linux/nospec.h>
 #include <linux/indirect_call_wrapper.h>
+#include <linux/agent_namespaces.h>

 #include <linux/uaccess.h>
 #include <asm/unistd.h>
@@ -1986,6 +1987,7 @@ int __sys_connect(int fd, struct sockaddr __user *uservaddr, int addrlen)
 	err = __sys_connect_file(sock->file, &address, addrlen, 0);
 out_put:
 	fput_light(sock->file, fput_needed);
+	agent_ns_count_connect();
 out:
 	return err;
 }
